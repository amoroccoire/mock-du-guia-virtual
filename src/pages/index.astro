---
import dependencies from "../data/dependencies.json";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Guia virtual para estudiantes">
	<div
		class="relative min-h-[calc(100vh-80px)] bg-gray-50 text-primary overflow-hidden font-body selection:bg-secondary selection:text-white flex flex-col"
	>
		<div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
			<div
				class="absolute top-10 left-10 w-64 h-64 border-2 border-primary/5 animate-float-slow"
			>
			</div>
			<div
				class="absolute bottom-20 right-20 w-96 h-96 border border-secondary/10 animate-float-slower"
			>
			</div>
		</div>

		<main
			class="w-full mx-auto px-1 lg:px-12 py-8 lg:py-12 relative z-10 grow flex flex-col justify-center transition-opacity duration-500 ease-in-out opacity-0"
			id="main-container"
		>
			<div
				class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-1 lg:gap-8 h-full items-stretch"
			>
				<section class="lg:col-span-1 flex flex-col h-full">
					<div
						class="bg-white rounded-sm shadow-xl relative overflow-hidden group hover:shadow-2xl transition-all duration-300 h-full flex flex-col"
						id="left-panel"
					>
						<div
							class="w-full h-full min-h-[400px] overflow-hidden shadow-inner relative flex-grow"
						>
							<iframe
								id="dep-video"
								class="absolute inset-0 w-full h-full object-cover"
								referrerpolicy="strict-origin-when-cross-origin"
								src={dependencies[0].video}
								title="Video de la dependencia"
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							>
							</iframe>
						</div>
					</div>
				</section>

				<aside class="lg:col-span-1 flex flex-col space-y-6 h-full">
					<div
						class="bg-white rounded-sm shadow-lg p-4 lg:p-8 flex flex-col h-full hover:shadow-xl transition-all duration-300"
						id="right-panel"
					>
						<div
							class="text-center mb-1 lg:mb-8 min-h-[120px] md:min-h-[150px] flex items-center justify-center"
						>
							<h1
								class="text-3xl lg:text-[2.3rem] font-montserrat font-normal leading-snug uppercase tracking-normal xl:tracking-widest text-[#141F40] text-balance"
								id="dep-title"
							>
								{dependencies[0].title}
							</h1>
						</div>

						<div class="mb-12 flex flex-col items-center">
							<div
								class="flex items-center justify-between w-full border-y border-gray-300 py-3 mb-3"
							>
								<button
									id="prev-btn"
									class="p-2 hover:bg-gray-100 rounded-full transition-colors focus:outline-none"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-6 w-6"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M15 19l-7-7 7-7"></path>
									</svg>
								</button>

								<span
									id="nav-indicator"
									class="text-center text-sm font-medium text-gray-700"
								>
									1/{dependencies.length}
									{dependencies[0].title}
								</span>

								<button
									id="next-btn"
									class="p-2 hover:bg-gray-100 rounded-full transition-colors focus:outline-none"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-6 w-6"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M9 5l7 7-7 7"></path>
									</svg>
								</button>
							</div>

							<div
								class="flex gap-2 w-2xs justify-center px-4"
								id="progress-bars"
							>
								{
									dependencies.map((_, index) => (
										<div
											class={`h-1.5 flex-1 transition-colors duration-300 ${index === 0 ? "bg-[#141F40]" : "bg-transparent border border-gray-400"}`}
											data-dot={index}
										/>
									))
								}
							</div>
						</div>

						<!--datos de contacto -->
						<div
							class="grid grid-cols-2 gap-y-6 gap-x-4 mb-4 lg:mb-12"
						>
							<div class="group">
								<h3
									class="font-semibold text-[#141F40] text-sm mb-1 uppercase"
								>
									Correo
								</h3>
								<a
									class="text-gray-600 text-sm hover:text-primary transition-colors block truncate"
									id="dep-email"
								>
									{dependencies[0].contact.email}
								</a>
							</div>

							<div class="group">
								<h3
									class="font-semibold text-[#141F40] text-sm mb-1 uppercase"
								>
									Dirección
								</h3>
								<p
									class="text-gray-600 text-sm leading-tight"
									id="dep-address"
								>
									{dependencies[0].contact.address}
								</p>
							</div>

							<div class="group">
								<h3
									class="font-semibold text-[#141F40] text-sm mb-1 uppercase"
								>
									Teléfono
								</h3>
								<div class="text-gray-600 text-sm">
									<p id="dep-phone">
										{dependencies[0].contact.phone}
									</p>
									<p class="text-xs text-gray-400 mt-0.5">
										Anexo: <span id="dep-extension"
											>{
												dependencies[0].contact
													.phoneExtension
											}</span
										>
									</p>
								</div>
							</div>

							<div class="group">
								<h3
									class="font-semibold text-[#141F40] text-sm mb-1 uppercase"
								>
									Responsable
								</h3>
								<div class="text-gray-600 text-sm">
									<p
										class="font-medium leading-tight"
										id="dep-responsible"
									>
										{dependencies[0].contact.responsible}
									</p>
									<p
										class="text-xs text-gray-400 mt-0.5"
										id="dep-role"
									>
										{
											dependencies[0].contact
												.responsibleRole
										}
									</p>
								</div>
							</div>
						</div>

						<!-- Redes sociales -->
						<div
							class="flex justify-center gap-6 mb-4 lg:mb-8 mt-[1rem] lg:mt-[-1rem]"
						>
							<a
								href="#"
								class="text-gray-600 hover:text-[#1877F2] transition-colors"
								aria-label="Facebook"
							>
								<svg
									class="w-5 h-5"
									fill="currentColor"
									viewBox="0 0 24 24"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
										clip-rule="evenodd"></path>
								</svg>
							</a>
							<a
								href="#"
								class="text-gray-600 hover:text-black transition-colors"
								aria-label="TikTok"
							>
								<svg
									class="w-5 h-5"
									fill="currentColor"
									viewBox="0 0 24 24"
									aria-hidden="true"
								>
									<path
										d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 2.58-1.54 5.14-3.9 6.27-2.38 1.15-5.32 1.06-7.58-.28-2.28-1.34-3.72-3.85-3.66-6.47.07-2.65 1.63-5.11 4.02-6.23 2.05-.96 4.49-.96 6.55.05.02-1.35.01-2.69.01-4.04-1.24-.71-2.73-.97-4.17-.79-1.17.15-2.29.62-3.21 1.34-1.24.97-2.06 2.45-2.36 3.98-.31 1.61-.09 3.3.66 4.74.78 1.48 2.08 2.61 3.61 3.1 1.57.51 3.32.48 4.88-.08 1.5-.53 2.76-1.57 3.51-2.93.74-1.35 1.05-2.92 1.01-4.47-.03-2.98-.02-5.96-.02-8.94-.01-1.39.02-2.78-.02-4.17z"
									></path>
								</svg>
							</a>
							<a
								href="#"
								class="text-gray-600 hover:text-[#E1306C] transition-colors"
								aria-label="Instagram"
							>
								<svg
									class="w-5 h-5"
									fill="currentColor"
									viewBox="0 0 24 24"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
										clip-rule="evenodd"></path>
								</svg>
							</a>
							<a
								href="#"
								class="text-gray-600 hover:text-black transition-colors"
								aria-label="Twitter/X"
							>
								<svg
									class="w-5 h-5"
									fill="currentColor"
									viewBox="0 0 24 24"
									aria-hidden="true"
								>
									<path
										d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"
									></path>
								</svg>
							</a>
						</div>

						<!--Crokis -->
						<div class="mt-auto border-t border-gray-100 pt-4">
							<div
								class="rounded-sm overflow-hidden shadow-md relative group h-48 w-full"
							>
								<img
									id="dep-image"
									src={dependencies[0].image}
									alt="Croquis de ubicación"
									class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
								/>
								<div
									class="absolute inset-0 flex items-center justify-center pointer-events-none"
								>
									<span
										class="bg-white/80 text-gray-800 px-4 py-2 font-bold tracking-widest uppercase rounded-sm backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity"
										>Croquis</span
									>
								</div>
								<div
									class="absolute bottom-0 left-0 w-full bg-linear-to-t from-primary/90 to-transparent p-3"
								>
									<p
										class="text-white text-xs font-semibold flex items-center gap-1"
									>
										<span class="text-secondary">📍</span>
										<span id="dep-location-text"
											>{
												dependencies[0].locationText
											}</span
										>
									</p>
								</div>
							</div>
						</div>
					</div>
				</aside>
			</div>
		</main>
	</div>
</Layout>

<script define:vars={{ dependencies }}>
	document.addEventListener("DOMContentLoaded", () => {
		const mainContainer = document.getElementById("main-container");
		const leftPanel = document.getElementById("left-panel");
		const rightPanel = document.getElementById("right-panel");

		// Elementos del DOM a actualizar
		const titleEl = document.getElementById("dep-title");
		const indicatorEl = document.getElementById("nav-indicator");
		const videoEl = document.getElementById("dep-video");
		const emailEl = document.getElementById("dep-email");
		const addressEl = document.getElementById("dep-address");
		const phoneEl = document.getElementById("dep-phone");
		const extensionEl = document.getElementById("dep-extension");
		const responsibleEl = document.getElementById("dep-responsible");
		const roleEl = document.getElementById("dep-role");
		const imageEl = document.getElementById("dep-image");
		const locationTextEl = document.getElementById("dep-location-text");
		const dots = document.querySelectorAll("[data-dot]");

		// Botones de navegación
		const prevBtn = document.getElementById("prev-btn");
		const nextBtn = document.getElementById("next-btn");

		let currentIndex = 0;

		// Initial Fade In
		setTimeout(() => {
			mainContainer.classList.remove("opacity-0");
			leftPanel.classList.add("animate-slide-in-left");
			rightPanel.classList.add("animate-slide-in-right");
		}, 100);

		const updateUI = (index) => {
			const data = dependencies[index];

			// 1. Animación de salida (Fade Out suave)
			leftPanel.classList.add("opacity-50");
			rightPanel.classList.add("opacity-50");

			setTimeout(() => {
				// 2. Actualizar Datos
				titleEl.textContent = data.title;
				indicatorEl.textContent = `${index + 1}/${dependencies.length} ${data.title}`;

				videoEl.src = data.video;
				emailEl.textContent = data.contact.email;
				emailEl.href = `mailto:${data.contact.email}`;
				addressEl.textContent = data.contact.address;
				phoneEl.textContent = data.contact.phone;
				extensionEl.textContent = data.contact.phoneExtension;
				responsibleEl.textContent = data.contact.responsible;
				roleEl.textContent = data.contact.responsibleRole;
				imageEl.src = data.image;
				locationTextEl.textContent = data.locationText;

				// Actualizar barras de progreso (dashes)
				dots.forEach((dot, i) => {
					if (i === index) {
						dot.className =
							"h-1.5 flex-1 transition-colors duration-300 bg-[#141F40]";
					} else {
						dot.className =
							"h-1.5 flex-1 transition-colors duration-300 bg-transparent border border-gray-400";
					}
				});

				// 3. Animación de entrada
				leftPanel.classList.remove("opacity-50");
				rightPanel.classList.remove("opacity-50");
			}, 250);
		};

		// Event Listeners para navegación
		prevBtn.addEventListener("click", () => {
			currentIndex =
				currentIndex === 0 ? dependencies.length - 1 : currentIndex - 1;
			updateUI(currentIndex);
		});

		nextBtn.addEventListener("click", () => {
			currentIndex =
				currentIndex === dependencies.length - 1 ? 0 : currentIndex + 1;
			updateUI(currentIndex);
		});
	});
</script>

<style>
	/* Custom Animations */
	@keyframes float-slow {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-20px);
		}
	}
	@keyframes float-slower {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-15px);
		}
	}

	.animate-float-slow {
		animation: float-slow 8s ease-in-out infinite;
	}
	.animate-float-slower {
		animation: float-slower 12s ease-in-out infinite;
	}

	/* Slide Animations */
	@keyframes slideInLeft {
		from {
			opacity: 0;
			transform: translateX(-50px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	@keyframes slideInRight {
		from {
			opacity: 0;
			transform: translateX(50px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.animate-slide-in-left {
		animation: slideInLeft 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}
	.animate-slide-in-right {
		animation: slideInRight 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}
</style>
