---
import dependencies from "../data/dependencies.json";
import Layout from "../layouts/Layout.astro";
import SplashScreen from "../components/SplashScreen.astro";
import Header from "../components/Header.astro";
import SocialMediaFloating from "../components/SocialMediaFloating.astro";
---

<Layout title="Guia virtual - UNSA">
	<SplashScreen />
	<Header />
	<div
		class="relative min-h-screen pt-[60px] bg-[#D9A86C] text-primary overflow-hidden font-body selection:bg-secondary selection:text-white flex flex-col"
	>
		<div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
			<div
				class="absolute top-10 left-10 w-64 h-64 border-2 border-primary/5 animate-float-slow"
			>
			</div>
			<div
				class="absolute bottom-20 right-20 w-96 h-96 border border-secondary/10 animate-float-slower"
			>
			</div>
		</div>

		<main
			class="w-full mx-auto px-1 lg:px-12 py-6 lg:py-10 relative z-10 grow flex flex-col justify-center transition-opacity duration-500 ease-in-out opacity-0"
			id="main-container"
		>
			<div
				class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-5 lg:gap-8 h-full items-stretch"
			>
				<section class="lg:col-span-1 flex flex-col h-full">
					<div
						class="bg-transparent rounded-sm shadow-xl relative overflow-hidden group hover:shadow-2xl transition-all duration-300 h-full flex flex-col"
						id="left-panel"
					>
						<div
							class="w-full h-full min-h-[400px] overflow-hidden shadow-inner relative flex-grow"
						>
							<iframe
								id="dep-video"
								class="absolute inset-0 w-full h-full object-cover"
								referrerpolicy="strict-origin-when-cross-origin"
								src={`${dependencies[0].video}?autoplay=1&mute=1`}
								title="Video de la dependencia"
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							>
							</iframe>
						</div>
					</div>
				</section>

				<aside class="lg:col-span-1 flex flex-col space-y-6 h-full">
					<div
						class="bg-[#f2f2f28c] lg:bg-[#f2f2f2e7] rounded-sm shadow-lg p-4 lg:p-8 flex flex-col h-full hover:shadow-xl transition-all duration-300"
						id="right-panel"
					>
						<div
							class="text-center mb-1 lg:mb-8 min-h-[120px] md:min-h-[150px] flex items-center justify-center"
						>
							<h1
								class="text-3xl lg:text-[2.3rem] font-montserrat font-normal leading-snug uppercase tracking-normal xl:tracking-widest text-[#141F40] text-balance"
								id="dep-title"
							>
								{dependencies[0].title}
							</h1>
						</div>

						<div class="mb-12 flex flex-col items-center">
							<div
								class="flex items-center justify-between w-full border-y border-gray-300 py-3 mb-3"
							>
								<button
									id="prev-btn"
									class="p-2 hover:bg-gray-100 rounded-full transition-colors focus:outline-none"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-6 w-6"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="4"
											d="M15 19l-7-7 7-7"></path>
									</svg>
								</button>

								<span
									id="nav-indicator"
									class="text-center text-sm font-bold text-gray-700"
								>
									1/{dependencies.length}
									{dependencies[0].title}
								</span>

								<button
									id="next-btn"
									class="p-2 hover:bg-gray-100 rounded-full transition-colors focus:outline-none"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-6 w-6"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="4"
											d="M9 5l7 7-7 7"></path>
									</svg>
								</button>
							</div>

							<div
								class="flex gap-2 w-2xs justify-center px-4"
								id="progress-bars"
							>
								{
									dependencies.map((_, index) => (
										<div
											class={`h-1.5 flex-1 transition-colors duration-300 ${index === 0 ? "bg-[#141F40]" : "bg-transparent border border-gray-400"}`}
											data-dot={index}
										/>
									))
								}
							</div>
						</div>

						<!--datos de contacto -->
						<div
							class="grid grid-cols-2 gap-y-6 gap-x-4 mb-4 lg:mb-12"
						>
							<div class="group">
								<h3
									class="font-semibold text-[#141F40] text-sm mb-1 uppercase"
								>
									Correo
								</h3>
								<a
									class="text-gray-600 text-sm hover:text-primary transition-colors block truncate"
									id="dep-email"
								>
									{dependencies[0].contact.email}
								</a>
							</div>

							<div class="group">
								<h3
									class="font-semibold text-[#141F40] text-sm mb-1 uppercase"
								>
									Dirección
								</h3>
								<p
									class="text-gray-600 text-sm leading-tight"
									id="dep-address"
								>
									{dependencies[0].contact.address}
								</p>
							</div>

							<div class="group">
								<h3
									class="font-semibold text-[#141F40] text-sm mb-1 uppercase"
								>
									Teléfono
								</h3>
								<div class="text-gray-600 text-sm">
									<p id="dep-phone">
										{dependencies[0].contact.phone}
									</p>
									<p class="text-xs text-gray-400 mt-0.5">
										Anexo: <span id="dep-extension"
											>{
												dependencies[0].contact
													.phoneExtension
											}</span
										>
									</p>
								</div>
							</div>

							<div class="group">
								<h3
									class="font-semibold text-[#141F40] text-sm mb-1 uppercase"
								>
									Responsable
								</h3>
								<div class="text-gray-600 text-sm">
									<p
										class="font-medium leading-tight"
										id="dep-responsible"
									>
										{dependencies[0].contact.responsible}
									</p>
									<p
										class="text-xs text-gray-400 mt-0.5"
										id="dep-role"
									>
										{
											dependencies[0].contact
												.responsibleRole
										}
									</p>
								</div>
							</div>
						</div>

						<!-- Redes sociales flotantes fijadas a la derecha -->
						<SocialMediaFloating />

						<!--Crokis -->
						<div class="mt-auto border-t border-gray-100 pt-4">
							<div
								class="rounded-sm overflow-hidden shadow-md relative group h-48 w-full"
							>
								<img
									id="dep-image"
									src={dependencies[0].image}
									alt="Croquis de ubicación"
									class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
								/>
								<div
									class="absolute inset-0 flex items-center justify-center pointer-events-none"
								>
									<span
										class="bg-white/80 text-gray-800 px-4 py-2 font-bold tracking-widest uppercase rounded-sm backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity"
										>Croquis</span
									>
								</div>
								<div
									class="absolute bottom-0 left-0 w-full bg-linear-to-t from-primary/90 to-transparent p-3"
								>
									<p
										class="text-white text-xs font-semibold flex items-center gap-1"
									>
										<span class="text-secondary">📍</span>
										<span id="dep-location-text"
											>{
												dependencies[0].locationText
											}</span
										>
									</p>
								</div>
							</div>
						</div>
					</div>
				</aside>
			</div>
		</main>
	</div>
</Layout>

<script define:vars={{ dependencies }}>
	document.addEventListener("DOMContentLoaded", () => {
		const mainContainer = document.getElementById("main-container");
		const leftPanel = document.getElementById("left-panel");
		const rightPanel = document.getElementById("right-panel");

		// Elementos del DOM a actualizar
		const titleEl = document.getElementById("dep-title");
		const indicatorEl = document.getElementById("nav-indicator");
		const videoEl = document.getElementById("dep-video");
		const emailEl = document.getElementById("dep-email");
		const addressEl = document.getElementById("dep-address");
		const phoneEl = document.getElementById("dep-phone");
		const extensionEl = document.getElementById("dep-extension");
		const responsibleEl = document.getElementById("dep-responsible");
		const roleEl = document.getElementById("dep-role");
		const imageEl = document.getElementById("dep-image");
		const locationTextEl = document.getElementById("dep-location-text");
		const dots = document.querySelectorAll("[data-dot]");

		// Botones de navegación
		const prevBtn = document.getElementById("prev-btn");
		const nextBtn = document.getElementById("next-btn");

		let currentIndex = 0;

		// Initial Fade In
		setTimeout(() => {
			mainContainer.classList.remove("opacity-0");
			leftPanel.classList.add("animate-slide-in-left");
			rightPanel.classList.add("animate-slide-in-right");
		}, 100);

		const updateUI = (index) => {
			const data = dependencies[index];

			// 1. Animación de salida (Fade Out suave)
			leftPanel.classList.add("opacity-50");
			rightPanel.classList.add("opacity-50");

			setTimeout(() => {
				// 2. Actualizar Datos
				titleEl.textContent = data.title;
				indicatorEl.textContent = `${index + 1}/${dependencies.length} ${data.title}`;

				const videoUrl = new URL(data.video);
				videoUrl.searchParams.set("autoplay", "1");
				videoUrl.searchParams.set("mute", "1");
				videoEl.src = videoUrl.toString();
				emailEl.textContent = data.contact.email;
				emailEl.href = `mailto:${data.contact.email}`;
				addressEl.textContent = data.contact.address;
				phoneEl.textContent = data.contact.phone;
				extensionEl.textContent = data.contact.phoneExtension;
				responsibleEl.textContent = data.contact.responsible;
				roleEl.textContent = data.contact.responsibleRole;
				imageEl.src = data.image;
				locationTextEl.textContent = data.locationText;

				// Actualizar barras de progreso (dashes)
				dots.forEach((dot, i) => {
					if (i === index) {
						dot.className =
							"h-1.5 flex-1 transition-colors duration-300 bg-[#141F40]";
					} else {
						dot.className =
							"h-1.5 flex-1 transition-colors duration-300 bg-transparent border border-gray-400";
					}
				});

				// 3. Animación de entrada
				leftPanel.classList.remove("opacity-50");
				rightPanel.classList.remove("opacity-50");
			}, 250);
		};

		// Event Listeners para navegación
		prevBtn.addEventListener("click", () => {
			currentIndex =
				currentIndex === 0 ? dependencies.length - 1 : currentIndex - 1;
			updateUI(currentIndex);
		});

		nextBtn.addEventListener("click", () => {
			currentIndex =
				currentIndex === dependencies.length - 1 ? 0 : currentIndex + 1;
			updateUI(currentIndex);
		});
	});
</script>

<style>
	/* Custom Animations */
	@keyframes float-slow {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-20px);
		}
	}
	@keyframes float-slower {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-15px);
		}
	}

	.animate-float-slow {
		animation: float-slow 8s ease-in-out infinite;
	}
	.animate-float-slower {
		animation: float-slower 12s ease-in-out infinite;
	}

	/* Slide Animations */
	@keyframes slideInLeft {
		from {
			opacity: 0;
			transform: translateX(-50px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	@keyframes slideInRight {
		from {
			opacity: 0;
			transform: translateX(50px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.animate-slide-in-left {
		animation: slideInLeft 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}
	.animate-slide-in-right {
		animation: slideInRight 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}
</style>
