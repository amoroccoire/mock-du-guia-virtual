---
import SocialMediaFloating from "./SocialMediaFloating.astro";

interface Props {
    dependencies: any[];
}

const { dependencies } = Astro.props;
const initialData = dependencies[0];
const initialProfile =
    initialData.perfiles && initialData.perfiles.length > 0
        ? initialData.perfiles[0]
        : {};
---

<aside class="lg:col-span-1 flex flex-col space-y-6 h-full">
    <div
        class="bg-[#141F40] rounded-sm shadow-lg p-4 lg:p-8 flex flex-col h-full hover:shadow-xl transition-all duration-300"
        id="right-panel"
    >
        <!-- CABECERA (LOGO Y TÍTULO) -->
        <div
            class="text-center mb-1 lg:mb-4 min-h-[120px] md:min-h-[150px] flex items-center justify-center shrink-0"
        >
            {
                initialProfile.logo ? (
                    <img
                        id="dep-logo"
                        src={initialProfile.logo}
                        alt={initialData.titulo}
                        class="h-[80px] md:h-[110px] object-contain max-w-[80%] mb-2"
                    />
                ) : (
                    <img
                        id="dep-logo"
                        src=""
                        alt=""
                        class="h-[80px] md:h-[110px] object-contain max-w-[80%] hidden mb-2"
                    />
                )
            }

            <h1
                class={`text-[clamp(1.2rem,4vw,2.3rem)] leading-[1.1] font-normal uppercase text-white text-balance ${initialProfile.logo ? "mt-2" : "mt-0"}`}
                id="dep-title"
            >
                {initialData.titulo}
            </h1>
        </div>

        <!-- SECCIÓN MEDIA: DATOS Y TABS (Dinamizada con scroll para evitar desbordes) -->

        <div
            class="flex-1 overflow-y-auto custom-scrollbar flex flex-col gap-3 py-2 shrink-0 min-h-[150px]"
        >
            <!-- Datos Generales (Responsable y Correo) -->
            <div class="text-center border-b border-white/10 pb-3">
                <p
                    id="dep-resp-gral"
                    class="text-white/90 font-medium text-[clamp(0.9rem,1.5vw,1.1rem)] leading-tight"
                >
                    {initialData.responsableGral}
                </p>
                <p
                    id="dep-cargo-gral"
                    class="text-white/60 text-xs italic mt-0.5"
                >
                    {initialData.cargoGral}
                </p>
                <p
                    id="dep-email-gral"
                    class="text-secondary text-sm font-semibold mt-1"
                >
                    {initialData.emailGral ? `✉ ${initialData.emailGral}` : ""}
                </p>
            </div>

            <!-- Contenedor de Pestañas (Se inyecta por JS si hay > 1 perfil) -->
            <div
                id="dep-tabs-container"
                class="flex flex-wrap justify-center gap-1.5 mt-2 hidden"
            >
            </div>

            <!-- Datos Específicos (Teléfonos mapeados dinámicamente) -->
            <div class="flex flex-col items-center text-center mt-2">
                <div class="flex items-start gap-2 text-white/80 text-sm">
                    <span class="text-secondary mt-0.5">📞</span>
                    <div id="dep-phones" class="flex flex-col gap-0.5">
                        {
                            initialProfile.telefonos &&
                                initialProfile.telefonos.map((tel: string) => (
                                    <p>{tel}</p>
                                ))
                        }
                    </div>
                </div>
            </div>

            <!-- Redes Sociales -->
            <div class="mt-2 flex justify-center">
                <SocialMediaFloating />
            </div>
        </div>

        <!-- CARRUSEL/IMAGEN (SECCIÓN INFERIOR) -->
        <div class="mt-auto border-t border-gray-100 pt-4 shrink-0">
            <div
                class="rounded-sm overflow-hidden shadow-md relative group h-48 w-full cursor-pointer"
            >
                <img
                    id="dep-image"
                    src={initialProfile.images &&
                    initialProfile.images.length > 0
                        ? initialProfile.images[0]
                        : ""}
                    alt="Imagen de ubicación o sede"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div
                    class="absolute inset-0 flex items-center justify-center pointer-events-none"
                >
                    <span
                        class="bg-white/80 text-gray-800 px-4 py-2 font-bold tracking-widest uppercase rounded-sm backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity"
                        >Ver Galería</span
                    >
                </div>
                <div
                    class="absolute bottom-0 left-0 w-full bg-linear-to-t from-primary/90 to-transparent p-3"
                >
                    <p
                        class="text-white text-xs font-semibold flex items-center gap-1"
                    >
                        <span class="text-secondary">📍</span>
                        <span id="dep-location-text" class="line-clamp-2"
                            >{initialProfile.ubicacion}</span
                        >
                    </p>
                </div>
            </div>
        </div>
    </div>
</aside>

<style>
    /* Estilos del scrollbar interno */
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.3);
    }
</style>
