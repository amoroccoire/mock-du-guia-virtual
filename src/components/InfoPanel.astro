---
import SocialMediaFloating from "./SocialMediaFloating.astro";

interface Props {
    dependencies: any[];
}

const { dependencies } = Astro.props;
const initialData = dependencies[0];
---

<aside class="lg:col-span-1 flex flex-col space-y-6 h-full">
    <div
        class="bg-[#141F40] rounded-sm shadow-lg p-4 lg:p-8 flex flex-col h-full hover:shadow-xl transition-all duration-300"
        id="right-panel"
    >
        <div
            class="text-center mb-1 lg:mb-4 min-h-[120px] md:min-h-[150px] flex items-center justify-center"
        >
            {
                initialData.logo ? (
                    <img
                        id="dep-logo"
                        src={initialData.logo}
                        alt={initialData.title}
                        class="h-[80px] md:h-[110px] object-contain max-w-[80%]"
                    />
                ) : (
                    <img
                        id="dep-logo"
                        src=""
                        alt=""
                        class="h-[80px] md:h-[110px] object-contain max-w-[80%] hidden"
                    />
                )
            }

            <h1
                class={`text-[clamp(1.2rem,4vw,2.3rem)] leading-[1.1] font-normal uppercase text-white text-balance ${initialData.logo ? "hidden" : ""}`}
                id="dep-title"
            >
                {initialData.title}
            </h1>
        </div>

        <div
            class="border border-[#F2F2F2] rounded-full inline-flex items-center justify-center self-center w-full max-w-[95%] lg:max-w-md"
        >
            <div
                class="inline-flex flex-col items-center bg-gray-950 rounded-full w-full px-2 py-2 shadow-xl border-7 border-[#141F40]"
                style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255, 0.05) 0px, rgba(255,255,255, 0.05) 2px, transparent 2px, transparent 8px);"
            >
                <div class="flex items-center justify-between w-full gap-4">
                    <button
                        id="prev-btn"
                        class="p-4 bg-white rounded-full text-gray-900 shadow-md transition-transform hover:scale-105 focus:outline-none"
                        aria-label="Anterior"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="3"
                                d="M15 19l-7-7 7-7"></path>
                        </svg>
                    </button>

                    <span
                        id="nav-indicator"
                        class="text-center text-white font-medium flex-1 px-4 uppercase text-[min(3vw,0.9rem)] leading-tight line-clamp-2"
                    >
                        1/{dependencies.length}
                        {initialData.title}
                    </span>

                    <button
                        id="next-btn"
                        class="p-4 bg-white rounded-full text-gray-900 shadow-md transition-transform hover:scale-105 focus:outline-none"
                        aria-label="Siguiente"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="3"
                                d="M9 5l7 7-7 7"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div
            class="flex gap-2 w-full mx-auto mt-4 mb-8 px-4 inline-flex items-center justify-center self-center"
            id="progress-bars"
        >
            {
                dependencies.map((_, index) => (
                    <div
                        class={`h-1.5 w-18 transition-colors duration-300 ${index === 0 ? "bg-white" : "bg-transparent border border-gray-400"}`}
                        data-dot={index}
                    />
                ))
            }
        </div>

        <!--datos de contacto -->
        <div class="grid grid-cols-2 gap-y-6 gap-x-4 mb-4 lg:mb-12">
            <div class="group border-4 border-l-white pl-2">
                <h3 class="font-semibold text-white text-sm mb-1 uppercase">
                    Responsable
                </h3>
                <div class="text-white text-sm">
                    <p class="font-medium leading-tight" id="dep-responsible">
                        {initialData.contact.responsible}
                    </p>
                    <p class="text-xs text-white mt-0.5" id="dep-role">
                        {initialData.contact.responsibleRole}
                    </p>
                </div>
            </div>
            <div class="group border-4 border-l-white pl-2">
                <h3 class="font-semibold text-white text-sm mb-1 uppercase">
                    Correo
                </h3>
                <a
                    class="text-white text-sm hover:text-primary transition-colors block truncate"
                    id="dep-email"
                    href={`mailto:${initialData.contact.email}`}
                >
                    {initialData.contact.email}
                </a>
            </div>
            <div class="group border-4 border-l-white pl-2">
                <h3 class="font-semibold text-white text-sm mb-1 uppercase">
                    Teléfono
                </h3>
                <div class="text-white text-sm">
                    <p id="dep-phone">
                        {initialData.contact.phone}
                    </p>
                    <p class="text-xs text-white mt-0.5">
                        Anexo: <span id="dep-extension"
                            >{initialData.contact.phoneExtension}</span
                        >
                    </p>
                </div>
            </div>
            <div class="group border-4 border-l-white pl-2">
                <h3 class="font-semibold text-white text-sm mb-1 uppercase">
                    Dirección
                </h3>
                <p class="text-white text-sm leading-tight" id="dep-address">
                    {initialData.contact.address}
                </p>
            </div>
        </div>

        <!-- Redes sociales flotantes fijadas a la derecha -->
        <SocialMediaFloating networks={initialData.socialMedia} />

        <!--Crokis -->
        <div class="mt-auto border-t border-gray-100 pt-4">
            <div
                class="rounded-sm overflow-hidden shadow-md relative group h-48 w-full"
            >
                <img
                    id="dep-image"
                    src={initialData.image}
                    alt="Croquis de ubicación"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div
                    class="absolute inset-0 flex items-center justify-center pointer-events-none"
                >
                    <span
                        class="bg-white/80 text-gray-800 px-4 py-2 font-bold tracking-widest uppercase rounded-sm backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity"
                        >Croquis</span
                    >
                </div>
                <div
                    class="absolute bottom-0 left-0 w-full bg-linear-to-t from-primary/90 to-transparent p-3"
                >
                    <p
                        class="text-white text-xs font-semibold flex items-center gap-1"
                    >
                        <span class="text-secondary">📍</span>
                        <span id="dep-location-text"
                            >{initialData.locationText}</span
                        >
                    </p>
                </div>
            </div>
        </div>
    </div>
</aside>
