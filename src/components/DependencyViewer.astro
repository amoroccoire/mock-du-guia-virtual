---
import { getOficinas } from "../lib/data";
import VideoPanel from "./VideoPanel.astro";
import InfoPanel from "./InfoPanel.astro";

const oficinas = await getOficinas();
---

<div
    class="relative min-h-screen pt-[30px] bg-[#f0f1f5] text-primary overflow-hidden font-body selection:bg-secondary selection:text-white flex flex-col"
>
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
        <div
            class="absolute top-10 left-10 w-64 h-64 border-2 border-primary/5 animate-float-slow"
        >
        </div>
        <div
            class="absolute bottom-20 right-20 w-96 h-96 border border-secondary/10 animate-float-slower"
        >
        </div>
    </div>

    <main
        class="w-full mx-auto px-1 lg:px-12 py-6 lg:py-10 relative z-10 grow flex flex-col justify-center transition-opacity duration-500 ease-in-out opacity-100"
        id="main-container"
    >
        <div
            class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-5 lg:gap-8 h-full items-stretch"
        >
            <VideoPanel videoUrl={oficinas[0]?.video || ""} />
            <InfoPanel dependencies={oficinas} />
        </div>
    </main>
</div>

<script define:vars={{ oficinas }}>
    document.addEventListener("DOMContentLoaded", () => {
        let currentDepIndex = 0;
        let currentProfileIndex = 0;

        const mainContainer = document.getElementById("main-container");
        const leftPanel = document.getElementById("left-panel");
        const rightPanel = document.getElementById("right-panel");
        const indicatorEl = document.getElementById("nav-indicator");
        const dots = document.querySelectorAll("[data-dot]");
        const prevBtn = document.getElementById("prev-btn");
        const nextBtn = document.getElementById("next-btn");

        // Animación Inicial (Fade In / Slide)
        setTimeout(() => {
            if (mainContainer) {
                mainContainer.classList.remove("opacity-0");
                mainContainer.classList.add("opacity-100");
            }
            if (leftPanel) leftPanel.classList.add("animate-slide-in-left");
            if (rightPanel) rightPanel.classList.add("animate-slide-in-right");
        }, 100);

        // Función global para cambiar la dependencia (Úsala con tus botones o carrusel)
        window.changeDependency = (index) => {
            currentDepIndex = index;
            currentProfileIndex = 0; // Resetea a la primera pestaña al cambiar de unidad

            // 1. Animación de salida (Fade Out suave)
            if (leftPanel) leftPanel.classList.add("opacity-50");
            if (rightPanel) rightPanel.classList.add("opacity-50");

            setTimeout(() => {
                // 2. Actualizar la Interfaz con los nuevos datos
                updateGlobalUI();

                // 3. Animación de entrada (Fade In)
                if (leftPanel) leftPanel.classList.remove("opacity-50");
                if (rightPanel) rightPanel.classList.remove("opacity-50");
            }, 250);
        };

        // Función global para cambiar la pestaña interna (Sub-área)
        window.changeProfile = (profIndex) => {
            currentProfileIndex = profIndex;
            updateProfileUI();
        };

        function updateGlobalUI() {
            if (!dependencies || dependencies.length === 0) return;
            const dep = dependencies[currentDepIndex];

            // Textos de Cabecera (Se mantienen fijos por ID)
            const titleEl = document.getElementById("dep-title");
            if (titleEl) titleEl.textContent = dep.titulo || "";

            const respEl = document.getElementById("dep-resp-gral");
            if (respEl) respEl.textContent = dep.responsableGral || "";

            const cargoEl = document.getElementById("dep-cargo-gral");
            if (cargoEl) cargoEl.textContent = dep.cargoGral || "";

            const emailEl = document.getElementById("dep-email-gral");
            if (emailEl)
                emailEl.textContent = dep.emailGral ? `✉ ${dep.emailGral}` : "";

            // Video Iframe
            const iframe = document.getElementById("dep-video");
            if (iframe && dep.video)
                iframe.src = `${dep.video}?autoplay=1&mute=1`;

            // Actualizamos los puntos de navegación (dots) y el indicador textual
            if (indicatorEl) {
                indicatorEl.textContent = `${currentDepIndex + 1}/${dependencies.length} ${dep.titulo}`;
            }

            if (dots.length > 0) {
                dots.forEach((dot, i) => {
                    if (i === currentDepIndex) {
                        dot.classList.add("bg-white");
                        dot.classList.remove(
                            "bg-transparent",
                            "border",
                            "border-gray-400",
                        );
                    } else {
                        dot.classList.remove("bg-white");
                        dot.classList.add(
                            "bg-transparent",
                            "border",
                            "border-gray-400",
                        );
                    }
                });
            }

            updateProfileUI();
        }

        function updateProfileUI() {
            if (!dependencies || dependencies.length === 0) return;
            const dep = dependencies[currentDepIndex];
            const profile = dep.perfiles[currentProfileIndex];
            if (!profile) return;

            // 1. TABS: Mostrar botones solo si hay más de 1 perfil
            const tabsContainer = document.getElementById("dep-tabs-container");
            if (tabsContainer) {
                if (dep.perfiles.length > 1) {
                    tabsContainer.innerHTML = dep.perfiles
                        .map((p, idx) => {
                            const isActive = idx === currentProfileIndex;
                            const btnClass = isActive
                                ? "bg-secondary text-white border-secondary"
                                : "bg-transparent text-white/60 border-white/20 hover:bg-white/10 hover:text-white";
                            // Usa subArea si existe, si no, usa la audiencia
                            const label = p.subArea ? p.subArea : p.audiencia;
                            return `<button onclick="window.changeProfile(${idx})" class="px-2 py-1 text-xs font-semibold rounded-sm border transition-all ${btnClass}">${label}</button>`;
                        })
                        .join("");
                    tabsContainer.classList.remove("hidden");
                } else {
                    tabsContainer.innerHTML = "";
                    tabsContainer.classList.add("hidden");
                }
            }

            // 2. LOGO: El logo puede variar por sub-área
            const logoEl = document.getElementById("dep-logo");
            if (logoEl) {
                if (profile.logo) {
                    logoEl.src = profile.logo;
                    logoEl.classList.remove("hidden");
                } else {
                    logoEl.classList.add("hidden");
                }
            }

            // 3. TELÉFONOS
            const telContainer = document.getElementById("dep-phones");
            if (telContainer) {
                if (profile.telefonos && profile.telefonos.length > 0) {
                    telContainer.innerHTML = profile.telefonos
                        .map((t) => `<p>${t}</p>`)
                        .join("");
                    telContainer.parentElement.classList.remove("hidden");
                } else {
                    telContainer.parentElement.classList.add("hidden");
                }
            }

            // 4. CROQUIS Y UBICACIÓN
            const imageEl = document.getElementById("dep-image");
            if (imageEl && profile.croquis && profile.croquis.length > 0) {
                imageEl.src = profile.croquis[0];
            }

            const locEl = document.getElementById("dep-location-text");
            if (locEl) locEl.textContent = profile.ubicacion || "";

            // 5. EMITIR EVENTO DE REDES SOCIALES
            // Si tienes tu componente SocialMediaFloating escuchando este evento:
            const event = new CustomEvent("updateSocialMedia", {
                detail: { networks: profile.redes || [] },
            });
            document.dispatchEvent(event);
        }

        // Event Listeners para navegación principal (Botones Prev / Next)
        if (prevBtn) {
            prevBtn.addEventListener("click", () => {
                const newIndex =
                    currentDepIndex === 0
                        ? dependencies.length - 1
                        : currentDepIndex - 1;
                window.changeDependency(newIndex);
            });
        }

        if (nextBtn) {
            nextBtn.addEventListener("click", () => {
                const newIndex =
                    currentDepIndex === dependencies.length - 1
                        ? 0
                        : currentDepIndex + 1;
                window.changeDependency(newIndex);
            });
        }

        updateGlobalUI();
    });
</script>

<style>
    /* Custom Animations */
    @keyframes float-slow {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-20px);
        }
    }
    @keyframes float-slower {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-15px);
        }
    }

    .animate-float-slow {
        animation: float-slow 8s ease-in-out infinite;
    }
    .animate-float-slower {
        animation: float-slower 12s ease-in-out infinite;
    }

    /* Slide Animations */
    @keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .animate-slide-in-left {
        animation: slideInLeft 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }
    .animate-slide-in-right {
        animation: slideInRight 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }
</style>
