---

<div class="fixed right-0 top-1/2 -translate-y-1/2 z-[70] flex flex-col gap-[10px]">
    {socialLinks.map((link) => (
        <a 
            href={link.url}
            aria-label={link.name}
            class="group relative flex items-center justify-center w-[30px] h-[30px] md:w-[34px] md:h-[34px] bg-[#8C0712] translate-x-[8px] hover:translate-x-0 hover:bg-[#A8192A] hover:scale-[1.08] transition-all duration-200 ease-out shadow-[-2px_2px_8px_rgba(0,0,0,0.18)]"
            style="border-radius: 24px 4px 4px 24px;"
        >
            <!-- Icon -->
            <div set:html={link.icon} class="flex items-center justify-center" />

            <!-- Tooltip -->
            <div class="absolute right-full mr-2 hidden md:group-hover:flex items-center pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap">
                <span class="bg-[#1A1210] text-white text-[11px] px-2.5 py-1.5 rounded-sm font-medium tracking-wide">
                    {link.name}
                </span>
                <!-- Flecha del tooltip -->
                <div class="w-0 h-0 border-y-[4px] border-y-transparent border-l-[5px] border-l-[#1A1210]"></div>
            </div>
        </a>
    ))}
</div>
