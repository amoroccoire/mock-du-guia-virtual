---
/**
 * InfoPanel.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Panel derecho. Muestra:
 *   • Logo o título de la unidad   → datos de cabecera
 *   • Navegación prev/next
 *   • Responsable general + email general  → datos de cabecera
 *   • Accordion de perfiles        → ProfileAccordion.astro (dinámico)
 *
 * El JS de DependencyViewer.astro actualiza los campos de cabecera mediante IDs
 * y dispara el evento 'accordionUpdated' para re-renderizar el accordion vía
 * innerHTML (ver buildAccordionHTML en DependencyViewer.astro).
 * ─────────────────────────────────────────────────────────────────────────────
 */
import ImageLoader from './ImageLoader.astro';
import ProfileAccordion from './ProfileAccordion.astro';
import SocialMediaFloating from '../SocialMediaFloating.astro';
import type { Dependencia } from '../../lib/data';

interface Props {
    dependencies: Dependencia[];
}

const { dependencies } = Astro.props;
const initial = dependencies[0];
---

<aside class="lg:col-span-1 flex flex-col h-full">
    <div
        class="bg-[#141F40] rounded-sm shadow-lg p-4 lg:p-6 flex flex-col h-full hover:shadow-xl transition-all duration-300 gap-4"
        id="right-panel"
    >

        <!-- ── LOGO / TÍTULO ─────────────────────────────────────────── -->
        <div class="text-center min-h-[90px] flex items-center justify-center">
            {initial.perfiles[0]?.logo ? (
                <div id="dep-logo-wrapper" class="bg-white/5 p-2 rounded-full shadow-[0_0_25px_rgba(255,255,255,0.15)] backdrop-blur-sm border border-white/10">
                    <ImageLoader
                        src={`${initial.perfiles[0].logo}`}
                        alt={initial.titulo}
                        class="h-[70px] md:h-[90px] object-contain max-w-[80%] mx-auto"
                    />
                </div>
            ) : (
                <div id="dep-logo-wrapper" class="hidden">
                    <!-- se muestra dinámicamente si hay logo -->
                </div>
            )}

            <h1
                class={`text-[clamp(1.1rem,3.5vw,2rem)] leading-[1.15] font-normal uppercase text-white text-balance ${initial.perfiles[0]?.logo ? 'hidden' : ''}`}
                id="dep-title"
            >
                {initial.titulo}
            </h1>
        </div>

        <!-- ── NAVEGACIÓN PREV / NEXT ────────────────────────────────── -->
        <div class="border border-[#F2F2F2] rounded-full inline-flex items-center justify-center self-center w-full max-w-[95%] lg:max-w-md">
            <div
                class="inline-flex items-center bg-gray-950 rounded-full w-full px-2 py-2 shadow-xl border-7 border-[#141F40]"
                style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,.05) 0px, rgba(255,255,255,.05) 2px, transparent 2px, transparent 8px);"
            >
                <div class="flex items-center justify-between w-full gap-4">
                    <button
                        id="prev-btn"
                        class="p-3 bg-white rounded-full text-gray-900 shadow-md transition-transform hover:scale-105 focus:outline-none flex-shrink-0"
                        aria-label="Anterior"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </button>

                    <span
                        id="nav-indicator"
                        class="text-center text-white font-medium flex-1 px-2 uppercase text-[min(2.8vw,0.85rem)] leading-tight line-clamp-2"
                    >
                        1/{dependencies.length} {initial.titulo}
                    </span>

                    <button
                        id="next-btn"
                        class="p-3 bg-white rounded-full text-gray-900 shadow-md transition-transform hover:scale-105 focus:outline-none flex-shrink-0"
                        aria-label="Siguiente"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Barras de progreso -->
        <div class="flex gap-2 w-full px-4 items-center justify-center" id="progress-bars">
            {dependencies.map((_, index) => (
                <div
                    class={`h-1.5 flex-1 max-w-[3rem] transition-colors duration-300 ${index === 0 ? 'bg-white' : 'bg-transparent border border-gray-400'}`}
                    data-dot={index}
                />
            ))}
        </div>

        <!-- ── DATOS GENERALES DE CABECERA ───────────────────────────── -->
        <div class="grid grid-cols-2 gap-y-4 gap-x-4">
            <!-- Responsable General -->
            <div class="border-l-4 border-white pl-2 col-span-2 sm:col-span-1">
                <h3 class="font-semibold text-white text-xs mb-0.5 uppercase tracking-wider">Responsable</h3>
                <p class="font-medium text-white text-sm leading-tight" id="dep-responsible">
                    {initial.responsableGral}
                </p>
                <p class="text-white/60 text-xs mt-0.5" id="dep-role">
                    {initial.cargoGral}
                </p>
            </div>

            <!-- Email General -->
            <div class="border-l-4 border-white pl-2 col-span-2 sm:col-span-1">
                <h3 class="font-semibold text-white text-xs mb-0.5 uppercase tracking-wider">Correo</h3>
                <a
                    class="text-white text-sm hover:text-secondary transition-colors block truncate"
                    id="dep-email"
                    href={`mailto:${initial.emailGral}`}
                >
                    {initial.emailGral}
                </a>
            </div>
        </div>

        <!-- ── SEPARADOR ─────────────────────────────────────────────── -->
        <div class="border-t border-white/10 -mx-1"></div>

        <!-- ── ACCORDION DE PERFILES ─────────────────────────────────── -->
        <div class="flex-1 overflow-y-auto min-h-0 pr-0.5 scrollbar-thin" id="accordion-wrapper">
            <p class="text-white/40 text-[10px] uppercase tracking-widest mb-2">
                Perfiles / Audiencias
            </p>
            <ProfileAccordion perfiles={initial.perfiles} />
        </div>

        <!-- Redes sociales flotantes -->
        <SocialMediaFloating networks={[]} />

    </div>
</aside>

<style>
    .scrollbar-thin {
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.2) transparent;
    }
    .scrollbar-thin::-webkit-scrollbar {
        width: 4px;
    }
    .scrollbar-thin::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.2);
        border-radius: 2px;
    }
</style>