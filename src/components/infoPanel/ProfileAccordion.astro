---
import type { Perfil } from '../../lib/data';
import ImageLoader from './ImageLoader.astro';

interface Props {
    perfiles: Perfil[];
}

const { perfiles } = Astro.props;

// Íconos SVG inline para redes sociales comunes
const socialIcons: Record<string, string> = {
    facebook:  `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
    instagram: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>`,
    twitter:   `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
    youtube:   `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>`,
    linkedin:  `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
    tiktok:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>`,
    web:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
};

function getSocialIcon(nombre: string): string {
    const key = nombre.toLowerCase();
    for (const [k, v] of Object.entries(socialIcons)) {
        if (key.includes(k)) return v;
    }
    return socialIcons.web;
}
---

<div class="accordion-list flex flex-col gap-2" id="profiles-accordion">
    {perfiles.map((perfil, index) => (
        <div
            class="accordion-item border border-white/20 rounded-sm overflow-hidden"
            data-index={index}
        >
            <!-- Cabecera del ítem -->
            <button
                class="accordion-trigger w-full flex items-center justify-between px-3 py-2.5 text-left bg-white/5 hover:bg-white/10 transition-colors duration-200 group"
                aria-expanded={index === 0 ? 'true' : 'false'}
                data-accordion-btn
            >
                <div class="flex flex-col min-w-0">
                    <span class="text-white text-xs font-bold uppercase tracking-wider leading-tight truncate">
                        {perfil.audiencia || perfil.subArea || `Perfil ${index + 1}`}
                    </span>
                    {perfil.subArea && perfil.audiencia && (
                        <span class="text-white/50 text-[10px] truncate mt-0.5">
                            {perfil.subArea}
                        </span>
                    )}
                </div>
                <svg
                    class="accordion-chevron h-4 w-4 text-white/60 flex-shrink-0 ml-2 transition-transform duration-300"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>

            <!-- Contenido del ítem -->
            <div
                class="accordion-content overflow-hidden transition-all duration-300 ease-in-out"
                style={index === 0 ? '' : 'max-height: 0;'}
            >
                <div class="px-3 py-3 space-y-3 bg-black/20">

                    <!-- Responsable del sub-área -->
                    {perfil.responsableArea && (
                        <div class="flex items-start gap-2">
                            <svg class="h-3.5 w-3.5 text-secondary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                            <span class="text-white/80 text-xs leading-tight">{perfil.responsableArea}</span>
                        </div>
                    )}

                    <!-- Teléfonos -->
                    {perfil.telefonos.length > 0 && (
                        <div class="flex items-start gap-2">
                            <svg class="h-3.5 w-3.5 text-secondary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                            <div class="flex flex-col gap-0.5">
                                {perfil.telefonos.map((tel) => (
                                    <a
                                        href={`tel:${tel.replace(/\s/g, '')}`}
                                        class="text-white/80 text-xs hover:text-secondary transition-colors"
                                    >
                                        {tel}
                                    </a>
                                ))}
                            </div>
                        </div>
                    )}

                    <!-- Ubicación -->
                    {perfil.ubicacion && (
                        <div class="flex items-start gap-2">
                            <svg class="h-3.5 w-3.5 text-secondary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                            </svg>
                            <span class="text-white/80 text-xs leading-tight">{perfil.ubicacion}</span>
                        </div>
                    )}

                    <!-- Redes Sociales -->
                    {perfil.redes.length > 0 && (
                        <div class="flex flex-wrap gap-2 pt-1">
                            {perfil.redes.map((red) => (
                                <a
                                    href={red.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    title={red.nombre}
                                    class="h-7 w-7 flex items-center justify-center rounded-full bg-white/10 hover:bg-secondary hover:text-white text-white/70 transition-all duration-200 hover:scale-110"
                                >
                                    <span class="h-3.5 w-3.5" set:html={getSocialIcon(red.nombre)} />
                                </a>
                            ))}
                        </div>
                    )}

                    <!-- Carrusel de imágenes del perfil -->
                    {perfil.images.length > 0 && (
                        <div class="pt-1">
                            <p class="text-white/40 text-[10px] uppercase tracking-wider mb-1.5">Galería</p>
                            <div class="carousel-track flex gap-2 overflow-x-auto snap-x snap-mandatory pb-1 scrollbar-none">
                                {perfil.images.map((imgSrc, imgIdx) => (
                                    <div class="snap-start flex-shrink-0 w-24 h-16 rounded-sm overflow-hidden bg-white/5">
                                        <ImageLoader
                                            src={imgSrc}
                                            alt={`Imagen ${imgIdx + 1} de ${perfil.audiencia}`}
                                            class="w-full h-full object-cover"
                                            width={96}
                                            height={64}
                                        />
                                    </div>
                                ))}
                            </div>
                        </div>
                    )}

                </div>
            </div>
        </div>
    ))}
</div>

<style>
    .scrollbar-none {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .scrollbar-none::-webkit-scrollbar {
        display: none;
    }

    .accordion-item[data-open] .accordion-chevron {
        transform: rotate(180deg);
    }
</style>

<script>
    function initAccordion(container: HTMLElement) {
        const items = container.querySelectorAll<HTMLElement>('.accordion-item');

        items.forEach((item) => {
            const btn = item.querySelector<HTMLButtonElement>('[data-accordion-btn]');
            const content = item.querySelector<HTMLElement>('.accordion-content');
            if (!btn || !content) return;

            // Estado inicial: primero abierto
            const isFirst = item.dataset.index === '0';
            if (isFirst) {
                item.dataset.open = '';
                content.style.maxHeight = content.scrollHeight + 'px';
            }

            btn.addEventListener('click', () => {
                const isOpen = 'open' in item.dataset;

                // Cerrar todos
                items.forEach((other) => {
                    const otherContent = other.querySelector<HTMLElement>('.accordion-content');
                    if (otherContent) otherContent.style.maxHeight = '0';
                    delete other.dataset.open;
                    const otherBtn = other.querySelector<HTMLButtonElement>('[data-accordion-btn]');
                    otherBtn?.setAttribute('aria-expanded', 'false');
                });

                // Abrir el clickeado (si no estaba abierto)
                if (!isOpen) {
                    item.dataset.open = '';
                    content.style.maxHeight = content.scrollHeight + 'px';
                    btn.setAttribute('aria-expanded', 'true');
                }
            });
        });
    }

    // Inicialización en carga
    document.addEventListener('DOMContentLoaded', () => {
        const accordion = document.getElementById('profiles-accordion');
        if (accordion) initAccordion(accordion);
    });

    // Re-inicialización cuando DependencyViewer actualiza el DOM
    document.addEventListener('accordionUpdated', () => {
        const accordion = document.getElementById('profiles-accordion');
        if (accordion) initAccordion(accordion);
    });
</script>