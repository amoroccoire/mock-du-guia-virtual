---
interface Props {
    videoUrl: string;
}

const { videoUrl } = Astro.props;
---

<section class="lg:col-span-1 flex flex-col h-full">
    <div
        class="bg-transparent rounded-sm shadow-2xl relative overflow-hidden group hover:shadow-2xl transition-all duration-300 h-full flex flex-col"
        id="left-panel"
    >
        <div
            class="w-full h-full min-h-[400px] overflow-hidden shadow-inner relative grow"
        >
            <iframe
                id="dep-video"
                class="absolute inset-0 w-full h-full object-cover"
                referrerpolicy="strict-origin-when-cross-origin"
                src={`${videoUrl}?autoplay=1&mute=1`}
                title="Video de la dependencia"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
            >
            </iframe>
        </div>
    </div>
</section>
