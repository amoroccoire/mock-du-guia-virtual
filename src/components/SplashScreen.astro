---
import { Image } from "astro:assets";
import unsaLogo from "../assets/UNSA_SIN_FONDO.png";
import duLogo from "../assets/imagotipo_du_black.png";
---

<div id="splash-screen" class="splash-container">
    <div class="splash-content">
        <div class="logos-wrapper">
            <!-- Logo Izquierdo: UNSA -->
            <div class="logo-container">
                <Image src={unsaLogo} alt="Logo UNSA" class="logo-img" />
                <span class="logo-text"
                    >UNIVERSIDAD NACIONAL<br />DE SAN AGUSTÍN</span
                >
            </div>

            <!-- Separador -->
            <div class="separator-container">
                <div class="separator-line"></div>
            </div>

            <!-- Logo Derecho: Oficina -->
            <div class="logo-container">
                <Image
                    src={duLogo}
                    alt="Logo Defensoria Universitaria"
                    class="logo-img"
                />
                <span class="logo-text">DEFENSORIA<br />UNIVERSITARIA</span>
            </div>
        </div>

        <!-- Tagline -->
        <div class="tagline">Te escuchamos y te orientamos</div>
    </div>

    <div class="progress-bar-container">
        <div class="progress-bar"></div>
    </div>
</div>

<style>
    /* Bloquear scroll general cuando splash está activo */
    :global(body.splash-active) {
        overflow: hidden !important;
    }

    /* Base Container */
    .splash-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #8c0712; /* Navy oscuro */
        z-index: 99999;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: #c9a84c; /* Dorado */
        font-family: "Montserrat", system-ui, sans-serif;
        transition: opacity 0.5s ease-in-out;
    }

    .splash-container.hide {
        opacity: 0;
        pointer-events: none;
    }

    .splash-container.remove {
        display: none !important;
    }

    /* Content Wrapper */
    .splash-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
    }

    /* Logos Area */
    .logos-wrapper {
        display: flex;
        align-items: stretch;
        justify-content: center;
        gap: 3rem;
    }

    .logo-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        opacity: 0;
        transform: translateY(20px);
    }

    .logo-img {
        width: 100px;
        height: 100px;
        object-fit: contain;
    }

    .logo-text {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        text-align: center;
        line-height: 1.5;
        font-weight: 800;
    }

    /* Separator */
    .separator-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 2px;
    }

    .separator-line {
        width: 1px;
        height: 0;
        background-color: #c9a84c;
        opacity: 0.6;
    }

    /* Tagline */
    .tagline {
        font-size: 0.75rem;
        letter-spacing: 0.25em;
        opacity: 0;
        text-transform: uppercase;
        color: rgba(201, 168, 76, 0.7);
        margin-top: 1rem;
        font-weight: 600;
    }

    /* Progress Bar */
    .progress-bar-container {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background-color: rgba(201, 168, 76, 0.15);
    }

    .progress-bar {
        height: 100%;
        width: 0%;
        background-color: #c9a84c;
    }

    /* ANIMATIONS */
    /* 1. Separator Line */
    .splash-container.animating .separator-line {
        animation: growLine 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        animation-delay: 0.3s;
    }

    @keyframes growLine {
        0% {
            height: 0;
        }
        100% {
            height: 100%;
        }
    }

    /* 2. Logos */
    .splash-container.animating .logo-container {
        animation: fadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        animation-delay: 0.9s;
    }

    @keyframes fadeUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 3. Tagline */
    .splash-container.animating .tagline {
        animation: fadeIn 1s ease-out forwards;
        animation-delay: 1.6s;
    }

    @keyframes fadeIn {
        0% {
            opacity: 0;
        }
        100% {
            opacity: 1;
        }
    }

    /* 4. Progress Bar */
    .splash-container.animating .progress-bar {
        animation: loadProgress 5.5s linear forwards; /* Animates smoothly along the 5s visible time */
    }

    @keyframes loadProgress {
        0% {
            width: 0%;
        }
        100% {
            width: 100%;
        }
    }

    @media (max-width: 640px) {
        .logos-wrapper {
            gap: 1.5rem;
        }
        .logo-img {
            width: 70px;
            height: 70px;
        }
        .logo-text {
            font-size: 0.6rem;
        }
        .tagline {
            font-size: 0.6rem;
            text-align: center;
            padding: 0 1rem;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const splashScreen = document.getElementById("splash-screen");
        const hasVisited = localStorage.getItem("hasVisitedSplash");

        if (!hasVisited && splashScreen) {
            document.body.classList.add("splash-active");

            requestAnimationFrame(() => {
                splashScreen.classList.add("animating");
            });

            // 5 seconds duration as requested
            setTimeout(() => {
                splashScreen.classList.add("hide"); // triggers opacity transition
                document.body.classList.remove("splash-active");
                localStorage.setItem("hasVisitedSplash", "true");

                // Wait for fade out to complete before display: none
                setTimeout(() => {
                    splashScreen.classList.add("remove");
                }, 500); // 500ms transition time
            }, 5000);
        } else if (splashScreen) {
            // Already visited, hide immediately
            splashScreen.classList.add("remove");
        }
    });
</script>
