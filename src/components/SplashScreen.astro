---
import { Image } from "astro:assets";
import unsaLogo from "../assets/UNSA_SIN_FONDO.png";
import duLogo from "../assets/imagotipo_du_black.png";
---

<div
    id="splash-screen"
    class="fixed top-0 left-0 w-screen h-screen bg-[#8c0712] z-[99999] flex flex-col justify-center items-center text-[#c9a84c] font-['Montserrat',system-ui,sans-serif] transition-opacity duration-500 ease-in-out"
>
    <div class="flex flex-col items-center gap-12">
        <div class="flex items-stretch justify-center gap-6 sm:gap-12">
            <!-- Logo Izquierdo: UNSA -->
            <div
                class="logo-container flex flex-col items-center gap-5 opacity-0 translate-y-5"
            >
                <Image
                    src={unsaLogo}
                    alt="Logo UNSA"
                    class="w-[70px] h-[70px] sm:w-[100px] sm:h-[100px] object-contain"
                />
                <span
                    class="text-[0.6rem] sm:text-[0.8rem] uppercase tracking-[0.15em] text-center leading-[1.5] font-extrabold"
                    >UNIVERSIDAD NACIONAL<br />DE SAN AGUSTÍN</span
                >
            </div>

            <!-- Separador -->
            <div class="flex justify-center items-center w-[2px]">
                <div class="separator-line w-[1px] h-0 bg-[#c9a84c] opacity-60">
                </div>
            </div>

            <!-- Logo Derecho: Oficina -->
            <div
                class="logo-container flex flex-col items-center gap-5 opacity-0 translate-y-5"
            >
                <Image
                    src={duLogo}
                    alt="Logo Defensoria Universitaria"
                    class="w-[70px] h-[70px] sm:w-[100px] sm:h-[100px] object-contain"
                />
                <span
                    class="text-[0.6rem] sm:text-[0.8rem] uppercase tracking-[0.15em] text-center leading-[1.5] font-extrabold"
                    >DEFENSORIA<br />UNIVERSITARIA</span
                >
            </div>
        </div>

        <!-- Tagline -->
        <div
            class="tagline text-[0.6rem] sm:text-[0.75rem] tracking-[0.25em] opacity-0 uppercase text-[#c9a84c]/70 mt-4 font-semibold text-center px-4 sm:px-0"
        >
            Te escuchamos y te orientamos
        </div>
    </div>

    <div class="absolute bottom-0 left-0 w-full h-[3px] bg-[#c9a84c]/15">
        <div class="progress-bar h-full w-0 bg-[#c9a84c]"></div>
    </div>
</div>

<style>
    /* Bloquear scroll general cuando splash está activo */
    :global(body.splash-active) {
        overflow: hidden !important;
    }

    #splash-screen.hide {
        opacity: 0;
        pointer-events: none;
    }

    #splash-screen.remove {
        display: none !important;
    }

    /* ANIMATIONS */
    /* 1. Separator Line */
    #splash-screen.animating .separator-line {
        animation: growLine 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        animation-delay: 0.3s;
    }

    @keyframes growLine {
        0% {
            height: 0;
        }
        100% {
            height: 100%;
        }
    }

    /* 2. Logos */
    #splash-screen.animating .logo-container {
        animation: fadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        animation-delay: 0.9s;
    }

    @keyframes fadeUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 3. Tagline */
    #splash-screen.animating .tagline {
        animation: fadeIn 1s ease-out forwards;
        animation-delay: 1.6s;
    }

    @keyframes fadeIn {
        0% {
            opacity: 0;
        }
        100% {
            opacity: 1;
        }
    }

    /* 4. Progress Bar */
    #splash-screen.animating .progress-bar {
        animation: loadProgress 5.5s linear forwards; /* Animates smoothly along the 5s visible time */
    }

    @keyframes loadProgress {
        0% {
            width: 0%;
        }
        100% {
            width: 100%;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const splashScreen = document.getElementById("splash-screen");
        const hasVisited = localStorage.getItem("hasVisitedSplash");

        if (!hasVisited && splashScreen) {
            document.body.classList.add("splash-active");

            requestAnimationFrame(() => {
                splashScreen.classList.add("animating");
            });

            // 5 seconds duration as requested
            setTimeout(() => {
                splashScreen.classList.add("hide"); // triggers opacity transition
                document.body.classList.remove("splash-active");
                localStorage.setItem("hasVisitedSplash", "true");

                // Wait for fade out to complete before display: none
                setTimeout(() => {
                    splashScreen.classList.add("remove");
                }, 500); // 500ms transition time
            }, 5000);
        } else if (splashScreen) {
            // Already visited, hide immediately
            splashScreen.classList.add("remove");
        }
    });
</script>
